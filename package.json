{
  "name": "dnd-campaign-creator",
  "version": "1.0.0",
  "description": "A generic utility for compiling Markdown adventures into Google Docs with Drive image syncing.",
  "main": "src/index.js",
  "bin": {
    "campaign-creator": "./bin/campaign-creator.js"
  },
  "scripts": {
    "test": "node --test src/__tests__/*.test.js src/map/*.test.js",
    "format": "prettier --write '**/*.{js,md,json}'",
    "lint": "markdownlint '**/*.md' --ignore node_modules",
    "map:snapshots:update": "node bin/map-quality.js update",
    "map:snapshots:check": "node bin/map-quality.js check",
    "verify": "npm run lint && npm test && npm run map:snapshots:check",
    "check-links": "linkinator 'README.md' 'CONTRIBUTING.md' 'docs/**/*.md' 'examples/**/*.md' --skip '^(?!https?://)' --retry",
    "precommit": "npm run format && npm run lint",
    "prepare": "husky"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tre-systems/dnd-campaign-creator.git"
  },
  "keywords": [
    "dnd",
    "campaign",
    "google-docs",
    "markdown",
    "publishing",
    "5e"
  ],
  "author": "Robert Gilks",
  "license": "MIT",
  "type": "commonjs",
  "engines": {
    "node": ">=20"
  },
  "bugs": {
    "url": "https://github.com/tre-systems/dnd-campaign-creator/issues"
  },
  "homepage": "https://github.com/tre-systems/dnd-campaign-creator#readme",
  "dependencies": {
    "@google-cloud/local-auth": "^3.0.1",
    "dotenv": "^17.3.1",
    "googleapis": "^171.4.0",
    "marked": "^17.0.3",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "linkinator": "^7.6.1",
    "markdownlint-cli": "^0.47.0",
    "prettier": "^3.8.1"
  }
}
